generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  USER
  GUEST
}

  model User {   // control JS API
      id        String   @id @default(cuid())
      name      String
      email     String   @unique
      password  String
      role      Role     @default(USER)
      teamId    String?
      team      Team?    @relation(fields: [teamId], references: [id])
      createdAt DateTime @default(now())
      updatedAt DateTime @updatedAt

      @@index([email])
      @@index([role])
      @@index([teamId])
      @@map("users")   // database table name 
  }

  model Team {
    id          String   @id @default(cuid())
    name        String
    code        String   @unique
    description String?
    members     User[]
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
  }